{
  "compilerOptions": {
    "target": "ES2022",
    "module": "None",
    "lib": ["DOM", "ES2022"],
    "outDir": "./media",
    "rootDir": "./src/webview",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/webview/**/*"]
}
